.cart-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.cart-item {
  display: flex;
}

.cart-item image {
  flex: 0 0 180rpx;
  height: 180rpx;
  width: 180rpx;
}

.cart-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  justify-content: center;
  padding: 20rpx;
}

.name {
  font-size: 31rpx;
  font-weight: 800;
}

.remove {
  background: transparent;
  border: 1rpx solid rgba(48, 75, 47, 0.25);
  border-radius: 999rpx;
  color: #304b2f;
  font-size: 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  width: 130rpx;
}

.total {
  align-items: center;
  display: flex;
  font-size: 34rpx;
  font-weight: 900;
  justify-content: space-between;
  margin: 20rpx 0;
}

.preview-title {
  color: #304b2f;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.mono {
  font-family: Menlo, Consolas, monospace;
  margin-top: 10rpx;
}

.empty {
  color: #747265;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 34rpx;
}
