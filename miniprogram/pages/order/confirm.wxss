.items {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-bottom: 28rpx;
  padding: 26rpx;
}

.item {
  display: flex;
  gap: 20rpx;
}

.item image {
  border-radius: 12rpx;
  flex: 0 0 130rpx;
  height: 130rpx;
  width: 130rpx;
}

.item > view {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  justify-content: center;
}

.name {
  color: #24251f;
  font-size: 30rpx;
  font-weight: 800;
}

.total {
  align-items: center;
  border-top: 1rpx solid rgba(36, 37, 31, 0.12);
  display: flex;
  font-size: 34rpx;
  font-weight: 900;
  justify-content: space-between;
  padding-top: 22rpx;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  padding: 30rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field text {
  color: #304b2f;
  font-size: 28rpx;
  font-weight: 800;
}

.control,
.textarea {
  background: #fbf8f1;
  border: 1rpx solid rgba(36, 37, 31, 0.14);
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #24251f;
  font-size: 30rpx;
  min-height: 88rpx;
  padding: 0 22rpx;
  width: 100%;
}

.control {
  align-items: center;
  display: flex;
}

.textarea {
  height: 160rpx;
  padding-top: 20rpx;
}

.preview-title {
  color: #304b2f;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.empty {
  color: #747265;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 34rpx;
}
