<view class="page">
  <view class="eyebrow">Order Confirm</view>
  <view class="section-title">确认订单</view>

  <view wx:if="{{cart.length}}">
    <view class="items card">
      <view class="item" wx:for="{{cart}}" wx:key="id">
        <image src="{{item.image}}" mode="aspectFill" />
        <view>
          <text class="name">{{item.name}}</text>
          <text class="muted">{{item.priceLabel}} × {{item.quantity}}</text>
        </view>
      </view>
      <view class="total">
        <text>商品合计</text>
        <text>¥{{total}}</text>
      </view>
    </view>

    <form class="form card" bindsubmit="submitOrder">
      <view class="field">
        <text>履约方式</text>
        <picker range="{{fulfillmentOptions}}" value="{{fulfillmentIndex}}" bindchange="setFulfillment">
          <view class="control">{{fulfillmentOptions[fulfillmentIndex]}}</view>
        </picker>
      </view>

      <view class="field">
        <text>期望日期</text>
        <picker mode="date" value="{{deliveryDate}}" bindchange="setDeliveryDate">
          <view class="control">{{deliveryDateLabel}}</view>
        </picker>
      </view>

      <view class="field">
        <text>时段</text>
        <picker range="{{timeSlots}}" value="{{timeSlotIndex}}" bindchange="setTimeSlot">
          <view class="control">{{timeSlots[timeSlotIndex]}}</view>
        </picker>
      </view>

      <view class="field">
        <text>配送区域 / 自提备注</text>
        <input class="control" name="deliveryArea" placeholder="例如 鼓楼区 / 到店自提" />
      </view>

      <view class="field">
        <text>收花人</text>
        <input class="control" name="recipientName" placeholder="可选" />
      </view>

      <view class="field">
        <text>联系方式</text>
        <input class="control" name="contact" placeholder="微信 / 手机号" />
      </view>

      <view class="field">
        <text>卡片留言</text>
        <textarea class="textarea" name="cardMessage" placeholder="可选，写在花礼卡片上" />
      </view>

      <view class="field">
        <text>备注</text>
        <textarea class="textarea" name="notes" placeholder="颜色偏好、配送限制、替换花材等" />
      </view>

      <button class="button" form-type="submit">生成订单草稿</button>
      <button class="button secondary" bindtap="goCart">返回购物袋</button>
    </form>

    <view class="safe-note" wx:if="{{status}}">{{status}}</view>
    <view class="safe-note" wx:if="{{orderPreview}}">
      <view class="preview-title">订单草稿</view>
      <view>preview id: {{orderPreview.id}}</view>
      <view>下一步接口：{{orderPreview.nextApi}}</view>
      <view>{{orderPreview.message}}</view>
    </view>
  </view>

  <view wx:else class="empty card">
    <view>购物袋为空，无法确认订单。</view>
    <button class="button" bindtap="goCart">返回购物袋</button>
  </view>
</view>
