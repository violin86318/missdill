.form {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  margin-top: 34rpx;
  padding: 30rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field text {
  color: #304b2f;
  font-size: 28rpx;
  font-weight: 800;
}

.control,
.textarea {
  background: #fbf8f1;
  border: 1rpx solid rgba(36, 37, 31, 0.14);
  border-radius: 12rpx;
  color: #24251f;
  font-size: 30rpx;
  min-height: 88rpx;
  padding: 0 22rpx;
}

.control {
  align-items: center;
  display: flex;
}

.textarea {
  box-sizing: border-box;
  height: 180rpx;
  padding-top: 20rpx;
  width: 100%;
}

.status {
  color: #304b2f;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.7;
}
