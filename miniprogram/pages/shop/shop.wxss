.filter-scroll {
  margin: 10rpx -32rpx 28rpx;
  padding-left: 32rpx;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  padding-right: 32rpx;
}

.filter {
  background: transparent;
  border: 1rpx solid rgba(36, 37, 31, 0.15);
  border-radius: 999rpx;
  color: #747265;
  flex: 0 0 auto;
  font-size: 27rpx;
  height: 74rpx;
  line-height: 74rpx;
  margin: 0;
  padding: 0 30rpx;
}

.filter.active {
  background: #304b2f;
  color: #fff;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.product image {
  height: 420rpx;
  width: 100%;
}

.product-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
}

.product-name {
  color: #24251f;
  font-size: 34rpx;
  font-weight: 800;
}

.availability {
  color: #304b2f;
  font-size: 25rpx;
  font-weight: 700;
}

.product-foot {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.price {
  font-size: 36rpx;
  font-weight: 900;
}

.detail {
  border: 1rpx solid rgba(48, 75, 47, 0.3);
  border-radius: 999rpx;
  color: #304b2f;
  font-size: 26rpx;
  padding: 12rpx 22rpx;
}
